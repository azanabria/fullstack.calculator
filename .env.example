# ============================================================
# Environment Variables Reference
# Copy this file to .env and adjust values for your deployment.
# ============================================================

# ---- Backend (server/) ----

# Runtime environment: development | staging | production
APP_ENV=development

# HTTP port the API server listens on
PORT=8080

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Enable/disable HTTP request logging (chi middleware)
LOG_REQUESTS=true

# ---- Frontend (client/) ----

# API base URL (empty = use proxy; set for cross-origin deployments)
VITE_API_URL=

# Frontend development server port
CALCULATOR_FRONTEND_PORT=3000

# Backend target for Vite local proxy server (development only)
VITE_PROXY_TARGET=${CALCULATOR_BACKEND_URL:-http://localhost:8080}

# Environment label exposed to frontend code
VITE_APP_ENV=development
